{
  "name": "funchat-backend-2026",
  "version": "1.0.0",
  "description": "FunChat backend (Express + Socket.IO)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- nodemon src/server.js",
    "demo": "dotenv -e .env.demo -- node src/server.js",
